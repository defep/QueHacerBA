{
  "name": "@quehacerba/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build": "tsc",
    "migrate": "tsx src/migrate.ts",
    "migrate:create": "tsx src/migrate.ts create",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kysely": "^0.28.11",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
